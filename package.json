{
  "name": "coach-house-lms",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "preinstall": "node scripts/enforce-package-manager.mjs",
    "dev": "next dev",
    "clean:next": "node scripts/clean-next-cache.mjs",
    "check:next-cache": "node scripts/check-next-cache-size.mjs",
    "dev:opencode": "NEXT_PUBLIC_ENABLE_REACT_GRAB=1 next dev",
    "dev:grab": "NEXT_PUBLIC_ENABLE_REACT_GRAB=1 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "snapshots:build": "tsc -p tsconfig.snapshots.json",
    "snapshots:verify": "pnpm snapshots:build && node -r ./dist-snapshots/scripts/register-alias.js dist-snapshots/scripts/generate-snapshots.js",
    "snapshots:update": "pnpm snapshots:build && node -r ./dist-snapshots/scripts/register-alias.js dist-snapshots/scripts/generate-snapshots.js --update",
    "test:snapshots": "pnpm snapshots:verify",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "test:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "test:acceptance": "vitest run --config vitest.config.ts",
    "test": "pnpm test:snapshots && pnpm test:rls",
    "test:rls": "node supabase/tests/rls.test.mjs",
    "check:structure": "node scripts/check-structure-conventions.mjs",
    "check:routes": "node scripts/check-route-entry-contract.mjs",
    "check:features": "node scripts/check-feature-contract.mjs",
    "check:feature-scaffold": "node scripts/check-feature-scaffold-sync.mjs",
    "check:thresholds": "node scripts/check-threshold-regression.mjs",
    "check:boundaries": "node scripts/check-import-boundaries.mjs",
    "check:deprecated-imports": "node scripts/check-deprecated-imports.mjs",
    "check:workspace-storage": "node scripts/check-workspace-storage-boundary.mjs",
    "check:interaction-locks": "node scripts/check-interaction-lock-boundary.mjs",
    "check:react-grab": "node scripts/check-react-grab-ownership.mjs",
    "check:npm-supply-chain": "node scripts/check-npm-supply-chain.mjs",
    "check:large-files": "node scripts/check-large-files.mjs",
    "check:raw-buttons": "node scripts/check-raw-button-usage.mjs",
    "check:workspace-surfaces": "node scripts/check-workspace-tutorial-surface-tokens.mjs",
    "check:perf": "node scripts/check-performance-budgets.mjs",
    "check:prepush": "pnpm check:npm-supply-chain && pnpm check:large-files && pnpm lint && pnpm check:structure && pnpm check:routes && pnpm check:features && pnpm check:thresholds && pnpm check:boundaries && pnpm check:deprecated-imports && pnpm check:workspace-storage && pnpm check:interaction-locks && pnpm check:react-grab && pnpm check:workspace-surfaces && pnpm check:raw-buttons && pnpm test:snapshots && pnpm test:acceptance",
    "check:quality": "pnpm check:npm-supply-chain && pnpm check:large-files && pnpm lint && pnpm check:structure && pnpm check:routes && pnpm check:features && pnpm check:feature-scaffold && pnpm check:thresholds && pnpm check:boundaries && pnpm check:deprecated-imports && pnpm check:workspace-storage && pnpm check:interaction-locks && pnpm check:react-grab && pnpm check:workspace-surfaces && pnpm check:raw-buttons && pnpm test:snapshots && pnpm test:acceptance && pnpm test:rls && pnpm build && pnpm test:visual && pnpm check:perf",
    "setup:hooks": "node scripts/setup-git-hooks.mjs",
    "verify:stripe": "node --env-file=.env.local scripts/verify-stripe-runtime.mjs",
    "db:push": "supabase db push",
    "create:admin": "node --env-file=.env.local scripts/create-admin-user.mjs",
    "promote:admin": "node --env-file=.env.local scripts/promote-user-to-admin.mjs",
    "provision:admins": "node --env-file=.env.local scripts/provision-platform-admins.mjs",
    "seed:full-account": "node scripts/seed-full-account.mjs",
    "seed:validate": "node scripts/seed-full-account.mjs --dry-run true",
    "resource-map:source-search-plan": "node scripts/resource-map/build-source-search-plan.mjs",
    "data:discover": "node scripts/resource-map/data-discover.mjs",
    "data:ingest": "node scripts/resource-map/data-ingest.mjs",
    "data:check-links": "node scripts/resource-map/check-links.mjs",
    "data:source-freshness": "node scripts/resource-map/check-local-source-freshness.mjs",
    "data:retry-failed": "node scripts/resource-map/data-ingest.mjs --retry-failed",
    "data:refresh-stale": "node scripts/resource-map/data-ingest.mjs --stale",
    "data:run-jobs": "node scripts/resource-map/run-local-jobs.mjs",
    "data:reprocess": "node scripts/resource-map/reprocess-candidates.mjs",
    "resource-map:schema-status": "node scripts/resource-map/check-schema-status.mjs",
    "resource-map:schema-setup-sql": "node scripts/resource-map/print-schema-setup-sql.mjs",
    "resource-map:public-read-sql": "node scripts/resource-map/print-public-read-contract-sql.mjs",
    "resource-map:discover-sources": "node scripts/resource-map/discover-sources.mjs",
    "resource-map:validate-local": "node scripts/resource-map/validate-local-records.mjs",
    "resource-map:import": "node scripts/resource-map/import-records.mjs",
    "resource-map:match": "node scripts/resource-map/generate-match-candidates.mjs",
    "resource-map:review-imports": "node scripts/resource-map/review-import-records.mjs",
    "resource-map:review-matches": "node scripts/resource-map/review-match-candidates.mjs",
    "resource-map:promote": "node scripts/resource-map/promote-approved-records.mjs",
    "resource-map:source-freshness": "node scripts/resource-map/check-source-freshness.mjs",
    "scaffold:feature": "node scripts/new-feature.mjs",
    "verify:settings": "node scripts/verify-account-settings.mjs",
    "import:curriculum": "node scripts/import-curriculum.mjs"
